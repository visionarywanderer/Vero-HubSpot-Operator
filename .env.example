# App
NEXTAUTH_URL=https://vero-hubspot-operator.onrender.com
NEXTAUTH_SECRET=replace-with-long-random-secret
ALLOWED_GOOGLE_DOMAIN=verodigital.co
ALLOWED_GOOGLE_EMAILS=
ENCRYPTION_KEY=replace-with-long-random-32-plus-char-secret

# Google OAuth (for operator login)
GOOGLE_CLIENT_ID=replace-me
GOOGLE_CLIENT_SECRET=replace-me

# HubSpot OAuth (optional, for connect flow UI)
HUBSPOT_OAUTH_CLIENT_ID=
HUBSPOT_OAUTH_CLIENT_SECRET=
HUBSPOT_OAUTH_REDIRECT_URI=

# HubSpot token mode (single-portal fallback)
HUBSPOT_TOKEN=optional-private-app-token

# MCP (optional override; default is https://mcp.hubspot.com)
HUBSPOT_MCP_URL=https://mcp.hubspot.com

# LLM
ANTHROPIC_API_KEY=replace-me

# Runtime
NODE_ENV=production
PORT=10000
LOG_LEVEL=info
