    "OBJECT_PROPERTY": "{ type: 'OBJECT_PROPERTY', propertyName: 'string' }",
    "FIELD_DATA": "{ type: 'FIELD_DATA', actionId: 'string', dataKey: 'string' }",
    "ENROLLED_OBJECT": "{ type: 'ENROLLED_OBJECT' }",
    "INCREMENT": "{ type: 'INCREMENT', incrementAmount: number }"
  },
