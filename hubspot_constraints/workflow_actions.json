    "LIST_BRANCH": ["actionId", "type", "listBranches", "defaultBranchName", "defaultBranch"],
    "STATIC_BRANCH": ["actionId", "type", "inputValue", "staticBranches", "defaultBranchName", "defaultBranch"],
    "AB_TEST_BRANCH": ["actionId", "type", "testBranches"],
    "CUSTOM_CODE": ["actionId", "type", "runtime", "sourceCode", "connection"],
