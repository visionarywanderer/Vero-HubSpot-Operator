  "validEnrollmentTypes": ["EVENT_BASED", "LIST_BASED", "MANUAL"],
  "enrollmentTypes": {
    "EVENT_BASED": {
      "description": "Trigger on property change or event",
      "requiredFields": ["type", "shouldReEnroll", "eventFilterBranches"],
      "optionalFields": ["listMembershipFilterBranches", "refinementCriteria"]
    },
    "LIST_BASED": {
      "description": "Trigger when record meets list filter criteria",
      "requiredFields": ["type", "shouldReEnroll", "listFilterBranch"],
      "optionalFields": ["unEnrollObjectsNotMeetingCriteria", "reEnrollmentTriggersFilterBranches"]
    },
    "MANUAL": {
      "description": "No automatic enrollment",
      "requiredFields": ["type", "shouldReEnroll"]
    }
  },
  "validConnectionTypes": ["SINGLE_CONNECTION"],
  "edgeTypes": ["STANDARD", "GOTO"],
  "requiredWorkflowFields": ["type", "objectTypeId", "actions", "enrollmentCriteria", "isEnabled", "enrollmentSchedule", "timeWindows", "blockedDates", "customProperties", "dataSources", "suppressionListIds"],
  "optionalWorkflowFields": ["name", "description", "startActionId", "nextAvailableActionId", "uuid", "canEnrollFromSalesforce", "goalFilterBranch", "suppressionFilterBranch", "eventAnchor", "unEnrollmentSetting"],
